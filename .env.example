# Sherpa — Environment Variables
# Bun loads .env automatically — no dotenv needed.
#
# API keys should be stored via `sherpa setup` (uses macOS Keychain).
# Only use env vars here for overrides or non-sensitive config.

# Optional: Override Keychain-stored API key (not recommended)
# ANTHROPIC_API_KEY=

# Optional: MCP server paths (if not using settings.json)
GMAIL_MCP_PATH=
GOOGLE_CALENDAR_MCP_PATH=
TODOIST_MCP_PATH=
TODOIST_API_TOKEN=
OBSIDIAN_MCP_PATH=

# Optional: Obsidian vault for local docs/plans/goals
OBSIDIAN_VAULT_PATH=

# Optional: Override config directory (default: ~/.config/sherpa)
# SHERPA_CONFIG_DIR=
